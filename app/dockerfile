# Stage 1: Build dependencies
FROM python:3.12-slim AS builder

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --user -r requirements.txt

# Stage 2: Runtime image
FROM python:3.12-slim

# Create a non-root user — never run containers as root
RUN groupadd -r appgroup && useradd -r -g appgroup appuser

WORKDIR /app

# Copy installed packages from builder stage
COPY --from=builder /root/.local /home/appuser/.local

# Copy app code
COPY app.py .

# Give the non-root user ownership and ensure PATH includes their local packages
ENV PATH=/home/appuser/.local/bin:$PATH
RUN chown -R appuser:appgroup /app

# Switch to non-root user — this is the critical security control
USER appuser

EXPOSE 5000

# Run with gunicorn — production WSGI server, not Flask's dev server
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "2", "app:app"]